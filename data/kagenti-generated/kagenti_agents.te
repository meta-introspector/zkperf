policy_module(kagenti_agents, 1.0.0)

require {
    type bin_t; type usr_t; type tmp_t; type node_t;
    class file { read write getattr open create execute };
    class dir { read search open };
    class tcp_socket { create connect read write bind listen accept };
    class udp_socket { create connect read write };
    class process { setuid setgid signal };
}

# === fractranllama (shard 50, user mdupont) ===
type svc_fractranllama_t;
allow svc_fractranllama_t usr_t:file { read getattr open };
allow svc_fractranllama_t usr_t:dir { read search open };
allow svc_fractranllama_t bin_t:file { read getattr open execute };
allow svc_fractranllama_t node_t:tcp_socket { create connect bind listen accept read write };
allow svc_fractranllama_t tmp_t:file { read write create };
neverallow svc_fractranllama_t self:process { setuid setgid };
neverallow svc_fractranllama_t usr_t:file { write append };

