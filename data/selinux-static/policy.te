policy_module(zkperf_services, 1.0.0)

require {
    type unconfined_t;
    type httpd_t;
    type bin_t;
    type usr_t;
    type tmp_t;
    type node_t;
    class process { transition signal };
    class file { read write getattr open create };
    class dir { read search open };
    class tcp_socket { create connect read write };
    class udp_socket { create connect read write };
}

# === zone42_understanding ===
type svc_zone42_understanding_t;

# Read: workdir + exec paths
allow svc_zone42_understanding_t usr_t:file { read getattr open };
allow svc_zone42_understanding_t usr_t:dir { read search open };
allow svc_zone42_understanding_t bin_t:file { read getattr open execute };
# Network access
allow svc_zone42_understanding_t node_t:tcp_socket { create connect read write };
allow svc_zone42_understanding_t node_t:udp_socket { create connect read write };

# === fractran_meta_compiler ===
type svc_fractran_meta_compiler_t;

# Read: workdir + exec paths
allow svc_fractran_meta_compiler_t usr_t:file { read getattr open };
allow svc_fractran_meta_compiler_t usr_t:dir { read search open };
allow svc_fractran_meta_compiler_t bin_t:file { read getattr open execute };
# Write: /home/mdupont/projects/cicadia71/shards/fractran_meta_compiler, /home/mdupont/uucp/spool
type svc_fractran_meta_compiler_t_rw_t;
allow svc_fractran_meta_compiler_t svc_fractran_meta_compiler_t_rw_t:file { read write getattr open create };
allow svc_fractran_meta_compiler_t svc_fractran_meta_compiler_t_rw_t:dir { read search open };
# Network access
allow svc_fractran_meta_compiler_t node_t:tcp_socket { create connect read write };
allow svc_fractran_meta_compiler_t node_t:udp_socket { create connect read write };
allow svc_fractran_meta_compiler_t tmp_t:file { read write create };
# NoNewPrivileges enforced
neverallow svc_fractran_meta_compiler_t self:process { setuid setgid };
# ProtectSystem=strict
neverallow svc_fractran_meta_compiler_t usr_t:file { write append };

