allow svc_rust_mcp_services_t node_t:udp_socket { create connect read write };
allow svc_rust_mcp_services_t tmp_t:file { read write create };
# NoNewPrivileges enforced
neverallow svc_rust_mcp_services_t self:process { setuid setgid };
# ProtectSystem=strict
neverallow svc_rust_mcp_services_t usr_t:file { write append };

# === solfunmeme_service ===
type svc_solfunmeme_service_t;

# Read: workdir + exec paths
allow svc_solfunmeme_service_t usr_t:file { read getattr open };
allow svc_solfunmeme_service_t usr_t:dir { read search open };
allow svc_solfunmeme_service_t bin_t:file { read getattr open execute };
# Network access
allow svc_solfunmeme_service_t node_t:tcp_socket { create connect read write };
allow svc_solfunmeme_service_t node_t:udp_socket { create connect read write };
allow svc_solfunmeme_service_t tmp_t:file { read write create };
# NoNewPrivileges enforced
neverallow svc_solfunmeme_service_t self:process { setuid setgid };
# ProtectSystem=strict
neverallow svc_solfunmeme_service_t usr_t:file { write append };

