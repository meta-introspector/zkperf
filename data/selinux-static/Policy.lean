-- Dependency (After/Wants)
def dependsOn : SvcType → SvcType → Bool
  | _, _ => false

-- Information flow: allowed iff dependency exists
def flows (s o : SvcType) : Prop := dependsOn s o = true

-- Soundness: no network access without hasNetwork
theorem network_sound (s : SvcType) :
    hasNetwork s = false → ¬ (∃ p, p = "tcp_connect" ∧ hasNetwork s = true) := by
  intro h; intro ⟨_, _, h2⟩; simp [h] at h2

-- NoNewPrivileges prevents privilege escalation
theorem no_escalation (s : SvcType) :
    noNewPrivs s = true → ¬ (∃ p, p = "setuid" ∧ noNewPrivs s = false) := by
  intro h; intro ⟨_, _, h2⟩; simp [h] at h2
